ninja_required_version = 1.3
cxx = c++
sycl = icpx

cflags = -pthread -fno-strict-overflow -Wsign-compare -Wunreachable-code -DNDEBUG -g -O3 -Wall -O3 -fno-omit-frame-pointer -mno-omit-leaf-frame-pointer -fPIC -fPIC -I/home/edgeai/esimd_learning/include -I/home/edgeai/esimd_learning/csrc -I/home/edgeai/downstream/lib/python3.12/site-packages/torch/include -I/home/edgeai/downstream/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/opt/intel/oneapi/compiler/2025.3/include -I/opt/intel/oneapi/compiler/2025.3/include/sycl -I/home/edgeai/downstream/include -I/home/edgeai/.local/share/uv/python/cpython-3.12.13-linux-x86_64-gnu/include/python3.12 -c
post_cflags = -O3 -std=c++17 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE=""' '-DPYBIND11_STDLIB=""' '-DPYBIND11_BUILD_ABI=""' -DTORCH_EXTENSION_NAME=custom_esimd_kernels -D_GLIBCXX_USE_CXX11_ABI=1
cuda_dlink_post_cflags = 
sycl_cflags = -pthread -fno-strict-overflow -Wsign-compare -Wunreachable-code -DNDEBUG -g -O3 -Wall -O3 -fno-omit-frame-pointer -mno-omit-leaf-frame-pointer -fPIC -fPIC -I/home/edgeai/esimd_learning/include -I/home/edgeai/esimd_learning/csrc -I/home/edgeai/downstream/lib/python3.12/site-packages/torch/include -I/home/edgeai/downstream/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/opt/intel/oneapi/compiler/2025.3/include -I/opt/intel/oneapi/compiler/2025.3/include/sycl -I/home/edgeai/downstream/include -I/home/edgeai/.local/share/uv/python/cpython-3.12.13-linux-x86_64-gnu/include/python3.12 -c -fsycl -fsycl-targets=spir64_gen,spir64 -std=c++17 -sycl-std=2020
sycl_post_cflags = -ffast-math -fsycl-device-code-split=per_kernel -I/home/edgeai/downstream/lib/python3.12/site-packages/torch/include -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE=""' '-DPYBIND11_STDLIB=""' '-DPYBIND11_BUILD_ABI=""' -DTORCH_EXTENSION_NAME=custom_esimd_kernels -D_GLIBCXX_USE_CXX11_ABI=1
sycl_dlink_post_cflags = -fsycl -fsycl-targets=spir64_gen,spir64 -fsycl-link --offload-compress -Xs "-device pvc,bmg,dg2,arl-h,mtl-h,lnl-m,ptl-h,ptl-u"
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule sycl_compile
  command = $sycl $sycl_cflags -c -x c++ $in -o $out $sycl_post_cflags



rule sycl_devlink
  command = $sycl $in -o $out $sycl_dlink_post_cflags



build /home/edgeai/esimd_learning/build/temp.linux-x86_64-cpython-312/csrc/xpu/esimd_kernel.o: sycl_compile /home/edgeai/esimd_learning/csrc/xpu/esimd_kernel.sycl
build /home/edgeai/esimd_learning/build/temp.linux-x86_64-cpython-312/csrc/xpu/torch_extension.o: compile /home/edgeai/esimd_learning/csrc/xpu/torch_extension.cc



build /home/edgeai/esimd_learning/build/temp.linux-x86_64-cpython-312/csrc/xpu/sycl_dlink.o: sycl_devlink /home/edgeai/esimd_learning/build/temp.linux-x86_64-cpython-312/csrc/xpu/esimd_kernel.o /home/edgeai/esimd_learning/build/temp.linux-x86_64-cpython-312/csrc/xpu/torch_extension.o




